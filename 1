import pandas as pd
import statsmodels.formula.api as smf

# create men-centered versions of continuous variables
beauty['educ_c'] = beauty['educ'] - beauty['educ'].mean()
beauty['exper_c'] = beauty['exper'] - beauty['exper'].mean()

# create the centered sq term
beauty['expersq_c'] = beauty['exper_c']**2

# re-estimate the model using centered variables
# note: the'*' in the formula automatically includes main effects and interactions

model2_centered = smf.ols(
    'lwage ~ belavg + abvavg + female + educ_c + exper_c + expersq_c +'
    'female:belavg + female:abvavg + female:educ_c + female:exper_c + female:expersq_c',
    data=beauty
).fit(cov_type='HC3')

print(model2_centered.summary())

