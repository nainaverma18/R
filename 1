# -------------------------------
# 1. Load Required Libraries
# -------------------------------
install.packages("psych")
install.packages("corrplot")
install.packages("factoextra")

library(psych)
library(corrplot)
library(factoextra)

# -------------------------------
# 2. Load Dataset
# -------------------------------
data <- read.csv("/Users/sabarish/Downloads/Iris.csv")

# Remove Id column if present
if("Id" %in% colnames(data)) {
  data$Id <- NULL
}

# Select only numeric variables
X <- data[, sapply(data, is.numeric)]

# -------------------------------
# 3. Check Structure
# -------------------------------
str(X)
summary(X)

# -------------------------------
# 4. Correlation Matrix
# -------------------------------
cor_matrix <- cor(X)
print(cor_matrix)

# -------------------------------
# 5. Correlation Heatmap
# -------------------------------
corrplot(cor_matrix, method = "color", type = "upper",
         tl.col = "black", tl.srt = 45)

# -------------------------------
# 6. KMO Test (Optional but good)
# -------------------------------
KMO(X)

# -------------------------------
# 7. Bartlett Test
# -------------------------------
cortest.bartlett(X)

# -------------------------------
# 8. Perform PCA
# -------------------------------
pca_model <- prcomp(X, scale. = TRUE)

# -------------------------------
# 9. Summary of PCA
# -------------------------------
summary(pca_model)

# -------------------------------
# 10. Scree Plot
# -------------------------------
fviz_eig(pca_model)

# -------------------------------
# 11. Biplot
# -------------------------------
fviz_pca_biplot(pca_model, repel = TRUE)

# -------------------------------
# 12. Loadings
# -------------------------------
print(pca_model$rotation)

# -------------------------------
# 13. PC Scores
# -------------------------------
scores <- pca_model$x
head(scores)

