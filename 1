# -------------------------------
# 1. Load Required Libraries
# -------------------------------
install.packages("psych")
install.packages("corrplot")

library(psych)
library(corrplot)

# -------------------------------
# 2. Load Dataset
# -------------------------------
data <- read.csv("/Users/sabarish/Downloads/Iris.csv")

# Remove Id column if present
if("Id" %in% colnames(data)) {
  data$Id <- NULL
}

# Select numeric variables only
X <- data[, sapply(data, is.numeric)]

# -------------------------------
# 3. Correlation Matrix
# -------------------------------
cor_matrix <- cor(X)
print(cor_matrix)

# Heatmap
corrplot(cor_matrix, method = "color", type = "upper",
         tl.col = "black", tl.srt = 45)

# -------------------------------
# 4. KMO Test
# -------------------------------
KMO(X)

# -------------------------------
# 5. Bartlett Test
# -------------------------------
cortest.bartlett(X)

# -------------------------------
# 6. Eigenvalues
# -------------------------------
eigen_values <- eigen(cor_matrix)
print(eigen_values$values)

# -------------------------------
# 7. Scree Plot
# -------------------------------
plot(eigen_values$values, type="b",
     xlab="Factor Number",
     ylab="Eigenvalue",
     main="Scree Plot")

abline(h=1, col="red", lty=2)

# -------------------------------
# 8. Parallel Analysis
# -------------------------------
fa.parallel(X)

# -------------------------------
# 9. Factor Analysis (Varimax)
# -------------------------------
fa_varimax <- fa(X, nfactors=2, rotate="varimax", scores=TRUE)
print(fa_varimax, cut=0.4)

# Communalities
fa_varimax$communality

# Factor Scores
head(fa_varimax$scores)

# -------------------------------
# 10. Factor Analysis (Promax)
# -------------------------------
fa_promax <- fa(X, nfactors=2, rotate="promax", scores=TRUE)
print(fa_promax, cut=0.4)

# =========================================================
# END OF FA
# =========================================================




