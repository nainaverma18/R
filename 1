# COMPLETE LDA ANALYSIS
# =========================================================

# -------------------------------
# 1. Load Required Libraries
# -------------------------------
install.packages("MASS")
library(MASS)

# -------------------------------
# 2. Load Dataset
# -------------------------------
data <- read.csv("/Users/sabarish/Downloads/Iris.csv")

# Remove Id column if present
if("Id" %in% colnames(data)) {
  data$Id <- NULL
}

# Convert Species to factor
data$Species <- as.factor(data$Species)

# -------------------------------
# 3. Split Data (Train-Test)
# -------------------------------
set.seed(123)

train_index <- sample(1:nrow(data), 0.7*nrow(data))

train_data <- data[train_index, ]
test_data  <- data[-train_index, ]

# -------------------------------
# 4. Fit LDA Model
# -------------------------------
lda_model <- lda(Species ~ ., data=train_data)

lda_model   # shows priors and means

# -------------------------------
# 5. Predictions
# -------------------------------
pred <- predict(lda_model, test_data)

# -------------------------------
# 6. Confusion Matrix
# -------------------------------
conf_matrix <- table(test_data$Species, pred$class)
print(conf_matrix)

# -------------------------------
# 7. Accuracy
# -------------------------------
accuracy <- sum(diag(conf_matrix)) / sum(conf_matrix)
print(accuracy)

# -------------------------------
# 8. Cross Validation
# -------------------------------
lda_cv <- lda(Species ~ ., data=data, CV=TRUE)

cv_table <- table(data$Species, lda_cv$class)
print(cv_table)

cv_accuracy <- sum(diag(cv_table)) / sum(cv_table)
print(cv_accuracy)

# -------------------------------
# 9. LDA Plot
# -------------------------------
plot(lda_model)

# =========================================================
# END OF LDA
# =========================================================



